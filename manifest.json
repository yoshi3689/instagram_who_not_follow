{
	"manifest_version": 2,
	"name": "InstagramWhoFollows",
	"description": "Analyze your Instagram account and find users who don't follow you back.",
	"version": "1.0.0",
  "homepage_url": "https://github.com/yoshi3689/instagram_who_not_follow",
  "permissions": [
    "activeTab", "notifications"
  ],
	"background": {
		"scripts": [
			"background_script.js"
		]
	},
	"content_scripts": [
		{
			"matches": ["https://www.instagram.com/*"],
			"js": [
				"content_script.js"
			]
		}
	],
	"browser_action": {
  "default_icon": {
    "16": "icons/icon-16.svg",
    "32": "icons/icon-32.svg",
    "48": "icons/icon-48.svg",
    "64": "icons/icon-128.svg",
    "128": "icons/icon-128.svg"
  },

		"default_popup": "browserAction/index.html",
		"default_title": "InstagramWhoFollows"
	},
    "web_accessible_resources": [
     "./urls.js"
  ],
  "browser_specific_settings": {
  "gecko": {
    "id": "instagramwhofollows@yoshiyukinagai",
    "data_collection_permissions": {
      "required": [],
      "optional": []
    }
  }
}
}